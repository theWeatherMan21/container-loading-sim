{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "智能装箱模拟系统",
  "identifier": "com.containerloading.sim",
  "version": "1.0.0",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "node scripts/build-frontend.js",
    "devUrl": "http://localhost:8080"
  },
  "app": {
    "windows": [
      {
        "title": "智能装箱模拟系统",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
